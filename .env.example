# =============================================================================
# LLM Configuration
# We strongly recommend a hosted frontier model. OpenAI is preferred.
# =============================================================================

# OpenAI (preferred)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic Claude (fallback - requires: uv add langchain-anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-key

# Azure OpenAI (fallback)
# AZURE_OPENAI_API_KEY=your-key
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/

# =============================================================================
# Model Selection
# =============================================================================

# LLM Model (default: gpt-4o)
# Examples (in order of preference):
#   gpt-4o                           (OpenAI - recommended)
#   claude-sonnet-4-20250514                 (Anthropic - fallback)
#   azure_openai:your-deployment     (Azure - fallback)
#   ollama:llama3.1                  (Local - last resort, requires: uv add langchain-ollama)
# LLM_MODEL=gpt-4o

# Model temperature (default: 0.7)
# LLM_TEMPERATURE=0.7

# LangSmith tracing (useful for debugging)
# LANGSMITH_API_KEY=lsv2_your-langsmith-api-key
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_PROJECT=studybuddy
